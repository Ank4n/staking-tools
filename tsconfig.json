{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": [
    "shared/**/*.ts",
    "validator/**/*.ts",
    "balances/**/*.ts",
    "health/**/*.ts",
    "expenses/**/*.ts",
    "tools/**/*.ts"
  ]
}
